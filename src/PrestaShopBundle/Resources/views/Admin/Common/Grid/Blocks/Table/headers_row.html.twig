{# By default headers are not show for empty state unles the view option empty_state_without_headers is set to false #}
{% set emptyStateWithoutHeaders = grid.view_options.empty_state_without_headers is not defined or grid.view_options.empty_state_without_headers == true %}
<tr class="column-headers {% if grid.attributes.is_empty_state and emptyStateWithoutHeaders %}d-none{% endif %}">
  {% for column in grid.columns %}
    <th
      scope="col"
      data-type="{{ column.type }}"
      data-column-id="{{ column.id }}"
      >
      {{ column_header(column, grid) }}
    </th>
  {% endfor %}
</tr>
