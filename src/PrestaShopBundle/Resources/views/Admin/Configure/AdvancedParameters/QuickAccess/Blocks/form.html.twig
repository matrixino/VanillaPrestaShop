{% form_theme quickAccessForm '@PrestaShop/Admin/TwigTemplateForm/prestashop_ui_kit.html.twig' %}

{{ form_start(quickAccessForm) }}
<div class="card">
  <h3 class="card-header">
    {{ 'Quick access'|trans({}, 'Admin.Navigation.Menu') }}
  </h3>

  <div class="card-body">
    <div class="form-wrapper">
      {{ form_errors(quickAccessForm) }}
      {{ form_widget(quickAccessForm) }}
    </div>
  </div>

  <div class="card-footer">
    <div class="d-inline-flex">
      <a href="{{ path('admin_quick_accesses_index') }}" class="btn btn-outline-secondary">
        {{ 'Cancel'|trans({}, 'Admin.Actions') }}
      </a>
    </div>
    <div class="d-inline-flex float-right">
      <button class="btn btn-primary" id="save-button">{{ 'Save'|trans({}, 'Admin.Actions') }}</button>
    </div>
  </div>
</div>
{{ form_end(quickAccessForm) }}
